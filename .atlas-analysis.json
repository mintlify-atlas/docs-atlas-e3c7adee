{
  "projectType": "cli-tool",
  "projectName": "Buildkite Agent",
  "projectDescription": "An open-source, cross-platform build runner written in Go that polls Buildkite for jobs, executes them on your own infrastructure, and streams logs and artifacts back to Buildkite.",
  "theme": "aspen",
  "primaryColor": "#040404",
  "lightColor": "#23d88f",
